{
  "name": "klix",
  "version": "0.1.5",
  "description": "CLI d'indexage codebase pour Claude — 70-90% moins de tokens",
  "bin": {
    "klix": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile src/index.ts --outfile ./bin/klix",
    "build:all": "bun run build:linux && bun run build:macos && bun run build:macos-arm",
    "build:linux": "bun build --compile src/index.ts --target bun-linux-x64 --outfile ./bin/klix-linux-x64",
    "build:macos": "bun build --compile src/index.ts --target bun-darwin-x64 --outfile ./bin/klix-macos-x64",
    "build:macos-arm": "bun build --compile src/index.ts --target bun-darwin-arm64 --outfile ./bin/klix-macos-arm64",
    "test": "bun test --coverage",
    "test:watch": "bun test --watch",
    "test:run": "bun test",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "bun-types": "^1.3.10",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1"
  }
}
